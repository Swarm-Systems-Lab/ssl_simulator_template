[build-system]
requires = ["hatchling"]
build-backend = "hatchling.build"

[project]
name = "{{ project_slug }}"
version = "0.1.0"
description = "{{ description }}"
readme = "README.md"
requires-python = ">=3.12"
authors = [
    { name = "{{ author_name }}", email = "{{ author_email }}" }
]
dependencies = [
    # ssl_simulator's `examples` extra pulls in matplotlib/IPython/ipykernel
    "ssl_simulator[examples]>=0.4",
    "jupyterlab>=4.0",
    # Add other project dependencies here
]

# A real (if trivial) editable-installed package - controllers/robot_models/
# visualization import normally (e.g. `from {{ project_slug }}.controllers import X`)
# with no sys.path hacking needed in notebooks.
[tool.hatch.build.targets.wheel]
packages = ["src/{{ project_slug }}"]
